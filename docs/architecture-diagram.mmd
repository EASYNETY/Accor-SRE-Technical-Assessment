flowchart LR
  %% External
  Internet["Internet / Clients"]
  ALB["AWS ALB (HTTPS)\nIngress Controller"]

  subgraph EKS_Cluster [AWS EKS Cluster]
    direction TB
    ControlPlane["EKS Control Plane"]
    subgraph Private_Subnets [Private Subnets (3 AZs)]
      direction TB
      AppService["redemption-api Pods\nDeployment + HPA"]
      Redis["ElastiCache Redis"]
      Aurora["Amazon Aurora Multi-AZ"]
      SQS["Amazon SQS FIFO"]
      SecretsMgr["Secrets Manager / SSM"]
      Observability["Prometheus + Grafana\nFluent Bit + OpenTelemetry"]
    end
  end

  subgraph Network [VPC]
    direction LR
    Public["Public Subnets (ALB)"]
    Private["Private Subnets (EKS nodes)"]
  end

  Internet --> ALB
  ALB --> AppService
  AppService --> Redis
  AppService --> Aurora
  AppService --> SQS
  AppService --> SecretsMgr
  AppService --> Observability

  ALB --> Public
  AppService --> Private
  Public --> |"HTTPS"| ALB
  Private --> |"Pod traffic"| AppService

  subgraph Observability_Stack [Observability]
    Prom["Prometheus"]
    Graf["Grafana"]
    Fluent["Fluent Bit"]
    XRay["OpenTelemetry / X-Ray"]
  end

  Observability --> Prom
  Observability --> Graf
  Observability --> Fluent
  Observability --> XRay

  classDef aws fill:#ffedd5,stroke:#f97316,stroke-width:1px;
  classDef app fill:#dbeafe,stroke:#3b82f6,stroke-width:1px;
  classDef infra fill:#dcfce7,stroke:#22c55e,stroke-width:1px;
  classDef obs fill:#f8fafc,stroke:#64748b,stroke-width:1px;

  class ALB,Internet,Public,Private aws;
  class AppService,Redis,Aurora,SQS,SecretsMgr infra;
  class Observability,Prom,Graf,Fluent,XRay obs;
